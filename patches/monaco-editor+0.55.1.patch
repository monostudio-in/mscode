+
+//  DEV. SOU FIX: Prevent selection collapse & focus stealing globally for Monaco Native Menu
+if (typeof window !== 'undefined') {
+    // Using mousedown , because applying pointerdown or touchstart it can block scroll inside menu
+    window.addEventListener('mousedown', (e) => {
+        // Searching inside Shadow DOM 
+        const path = e.composedPath ? e.composedPath() : [];
+        
+        // Checking the tap inside Monaco's context-view (Native Menu) or Not
+        const isMenuClick = path.some(el => el.classList && el.classList.contains('context-view'));
+        
+        if (isMenuClick) {
+            // Prevent the browser from shifting focus and clearing the selection when the menu is clicked
+            // This ensures Monaco won't receive a selection change event, keeping the sub-menu open!
+            e.preventDefault();
+        }
+    }, { capture: true, passive: false });
+}
